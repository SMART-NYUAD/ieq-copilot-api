# ----------------------------
# Server runtime
# ----------------------------
RAG_API_HOST=0.0.0.0
RAG_API_PORT=8001

# Comma-separated values. Defaults in code allow "*", but explicit values are recommended.
RAG_API_CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
RAG_API_CORS_ALLOW_CREDENTIALS=true
RAG_API_CORS_ALLOW_METHODS=GET,POST,OPTIONS
RAG_API_CORS_ALLOW_HEADERS=*

# ----------------------------
# Router behavior
# ----------------------------
ROUTER_CLARIFY_THRESHOLD=0.5
AGENTIC_MODE=true
AGENT_ROUTING_STRICT=true
AGENT_MAX_STEPS=4
AGENT_MAX_CONSECUTIVE_FAILURES=2
AGENT_STALL_THRESHOLD=2
AGENT_STREAM_STEP_EVENTS=true

# LLM planner (routing)
OLLAMA_ROUTER_BASE_URL=http://127.0.0.1:11434
OLLAMA_ROUTER_MODEL=qwen3:30b-a3b-instruct-2507-q4_K_M
OLLAMA_ROUTER_TEMPERATURE=0.0
OLLAMA_ROUTER_TIMEOUT_SECONDS=20
OLLAMA_ROUTER_THINKING=false
OLLAMA_ROUTER_MAX_RETRIES=2
OLLAMA_ROUTER_RETRY_JITTER_MS=180

# LLM answer generation
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:30b-a3b-instruct-2507-q4_K_M

# ----------------------------
# Conversation memory
# ----------------------------
CONVERSATION_STORE_PATH=./data/conversation_turns.json
CONVERSATION_MAX_TURNS=24
CONVERSATION_CONTEXT_TURNS=12
CONVERSATION_CONTEXT_MAX_CHARS=4000
CONVERSATION_MESSAGE_MAX_CHARS=2000

# ----------------------------
# Database (keep in this .env only; no password.env)
# ----------------------------
DATABASE_URL=postgresql://<db_user>:<db_password>@<db_host>:5432/<db_name>
#
# Or omit DATABASE_URL and set components:
# DB_USER=<db_user>
# DB_PASSWORD=<db_password>
# DB_HOST=<db_host>
# DB_PORT=5432
# DB_NAME=<db_name>

